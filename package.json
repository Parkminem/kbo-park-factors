{
  "name": "kbo-park-factors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build && node scripts/wrap-sites-worker.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "update:daily": ".venv/bin/python pipeline/generate_daily_factors.py --prune-output-root",
    "validate:daily": ".venv/bin/python pipeline/validate_daily_factors.py",
    "smoke:game-day": ".venv/bin/python pipeline/smoke_game_day_ui.py",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "^5.8.0",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
